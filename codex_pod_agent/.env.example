# API keys
ANTHROPIC_API_KEY=
# 也支持 ANTHROPIC_AUTH_TOKEN（与 ANTHROPIC_API_KEY 二选一）
# 可选自定义 API 基础地址（企业代理/私有网关）：
ANTHROPIC_BASE_URL=
# 自定义模型名（例如 claude-sonnet-4-5）
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# 是否启用思考模式（如模型支持）
ANTHROPIC_THINKING=false
ANTHROPIC_THINK_TOKENS=1024
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
CLAUDE_USE_LOOP=false
DRY_RUN=true

# TTS provider: openai | elevenlabs | none
TTS_PROVIDER=edge
# Edge TTS 语音（示例中文音色，可按需替换）
TTS_VOICE_A=zh-CN-XiaoxiaoNeural
TTS_VOICE_B=zh-CN-YunxiNeural

# Podcast & output
PODCAST_FEED_TITLE=Daily AI Research Duo
PODCAST_FEED_AUTHOR=Your Name
PODCAST_BASE_URL=https://your-domain.example.com/podcast
OUTPUT_DIR=dist/episodes

# Schedule (cron-like local time, 24h)
SCHEDULE_TIME=09:00
CONTEXT_HISTORY=3
DEDUP_HISTORY=14
